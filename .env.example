# Supabase — supabase.com 프로젝트 Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# 구글 Web 클라이언트 ID (웹/네이티브 공용)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# 카카오 키는 Supabase 대시보드(Authentication → Providers → Kakao)에 입력

# 웹 Push VAPID 공개키 (없으면 웹은 setTimeout 폴백으로 동작)
# 생성: npx web-push generate-vapid-keys  → 공개키를 여기, 비밀키는 Supabase 시크릿으로
VITE_VAPID_PUBLIC_KEY=
